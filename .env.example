# FORGE Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# SPONSOR API KEYS (9 integrations)
# =============================================================================

# IronClaw - TEE-secured agent runtime
# Get your key from: https://ironclaw.near.ai
IRONCLAW_API_KEY=your_ironclaw_api_key_here
IRONCLAW_AGENT_ID=forge-agent

# OpenAI - LLM reasoning (GPT-4o)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7

# Tavily - Market search and discovery
# Get your key from: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=3

# Yutori - Deal monitoring scouts
# Get your key from: https://yutori.io
YUTORI_API_KEY=your_yutori_api_key_here
YUTORI_API_URL=https://api.yutori.io/v1

# Senso - Context verification and ground truth
# Get your key from: https://senso.ai
SENSO_API_KEY=your_senso_api_key_here
SENSO_API_URL=https://api.senso.ai/context

# Modulate - Voice command processing (Velma)
# Get your key from: https://modulate.ai
MODULATE_API_KEY=your_modulate_api_key_here
MODULATE_API_URL=https://api.modulate.ai/velma

# Numeric - Financial reconciliation
# Get your key from: https://numeric.io
NUMERIC_API_KEY=your_numeric_api_key_here
NUMERIC_API_URL=https://api.numeric.io/v1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Neo4j - Graph database for governance and audit trails
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=forgepassword
NEO4J_DATABASE=neo4j

# PostgreSQL - Backend for Airbyte
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=airbyte
POSTGRES_PASSWORD=airbyte
POSTGRES_DB=airbyte

# Airbyte - Data synchronization
AIRBYTE_API_URL=http://localhost:8000/api/v1
AIRBYTE_WEBAPP_URL=http://localhost:8001

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# API Server
API_PORT=3001
API_HOST=localhost
API_CORS_ORIGIN=http://localhost:3000

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_DASHBOARD_PORT=3000

# IronClaw Runtime
IRONCLAW_RUNTIME_PORT=8080
IRONCLAW_RUNTIME_HOST=localhost

# =============================================================================
# FEATURE FLAGS - Mock Fallbacks
# =============================================================================

# Enable mock responses when sponsor APIs are unavailable
# Set to 'true' to use mocks, 'false' to require real APIs
USE_MOCK_TAVILY=false
USE_MOCK_YUTORI=false
USE_MOCK_SENSO=false
USE_MOCK_MODULATE=false
USE_MOCK_NUMERIC=false

# Mock wallet configuration
MOCK_WALLET_INITIAL_BALANCE=1000.0
MOCK_WALLET_NETWORK=testnet

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# TEE Vault Configuration
TEE_VAULT_NAME=forge-credentials
TEE_VAULT_ENCRYPTION=aes-256-gcm

# NEAR Wallet (for mock transactions)
NEAR_NETWORK=testnet
NEAR_ACCOUNT_ID=forge-demo.testnet
# NOTE: Private key stored in IronClaw TEE vault, not in .env

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Performance
CACHE_TTL_SECONDS=300
API_TIMEOUT_MS=5000
MAX_RETRIES=3
RETRY_DELAY_MS=1000

# Demo Configuration
DEMO_USER_ID=demo-user-1
DEMO_FLOW_TIMEOUT_MS=15000
DEMO_MAX_CONSECUTIVE_RUNS=3

# =============================================================================
# DEPLOYMENT (Render)
# =============================================================================

# Render deployment URLs (set by Render automatically)
# RENDER_EXTERNAL_URL=https://forge-dashboard.onrender.com
# RENDER_INTERNAL_URL=http://forge-api:3001
